# Internal integration token from notion.so/profile/integrations/internal.
# Must be granted access to the Films database (Connections menu on the page).
NOTION_API_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Letterboxd username (the part after letterboxd.com/, e.g. "brianlovin").
LETTERBOXD_USER=yourusername

# Notion database ID of your Films DB. The 32-hex-char ID is in the URL when
# you open the database — `setup.ts` writes this for you automatically. The
# helper scripts resolve the underlying data source ID at runtime, so you
# only need the database ID here.
FILMS_DATABASE_ID=00000000-0000-0000-0000-000000000000
